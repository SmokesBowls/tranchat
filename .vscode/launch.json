{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "android",
            "name": "Debug Android App",
            "request": "launch",
            "appSrcRoot": "${workspaceRoot}/app/src/main",
            "apkFile": "${workspaceRoot}/app/build/outputs/apk/debug/app-debug.apk",
            "adbPort": 5037
        },
        {
            "type": "android",
            "name": "Attach to Android Process",
            "request": "attach",
            "processId": "${command:PickAndroidProcess}",
            "adbPort": 5037
        },
        {
            "type": "java",
            "name": "Run Unit Tests",
            "request": "launch",
            "mainClass": "org.junit.runner.JUnitCore",
            "args": ["${file}"],
            "sourcePaths": ["${workspaceRoot}/app/src/test/java"]
        },
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        }
    ]
}